# ─── App ───────────────────────────────────────────────
APP_NAME="Portaria Pro"
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/portaria_pro?schema=public"

# ─── JWT ───────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_STRONG_SECRET_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (choose one) ──────────────────────────────
# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Supabase Storage
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Email (SMTP) ──────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Portaria Pro <noreply@portariapro.com.br>"
